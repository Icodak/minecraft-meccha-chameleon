{
    "type": "minecraft:confirmation",
    "title": "Spawn location saver",
    "body": [
        {
            "type": "minecraft:plain_message",
            "contents": {
                "text": "Type the name of a new starting game location you want to save.\nYour current location will be used as the spawn point",
                "type": "text",
                "bold": false
            },
            "width": 350
        },
        {
            "type": "minecraft:plain_message",
            "contents": {
                "text": "There is no limit to the number of locations you can have so have fun :)",
                "color": "gray",
                "italic": true
            },
            "width": 300
        }
    ],
    "inputs": [
        {
            "type": "minecraft:text",
            "key": "meccha_location_name",
            "label": "Location name",
            "label_visible": true
        }
    ],
    "can_close_with_escape": true,
    "after_action": "close",
    "pause": false,
    "yes": {
        "label": "Save location",
        "action": {
            "type": "minecraft:dynamic/run_command",
            "template": "function meccha:spawn_location/save_new_location {name:\"$(meccha_location_name)\"}"
        }
    },
    "no": {
        "label": "Close without saving"
    }
}